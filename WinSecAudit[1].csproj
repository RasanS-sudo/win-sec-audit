using System.Text;
 
namespace WinSecAudit;
 
public static class HtmlReportGenerator
{
    public static string Generate(AuditResult result)
    {
        var sb = new StringBuilder();
 
        var categories = result.Findings
            .GroupBy(f => f.Category)
            .OrderBy(g => g.Key)
            .ToList();
 
        string riskColor = result.RiskTier switch
        {
            "CRITICAL" => "#ff2d55",
            "HIGH"     => "#ff6b35",
            "MEDIUM"   => "#ffd60a",
            _          => "#30d158"
        };
 
        string elevColor = result.IsElevated ? "var(--pass)" : "var(--high)";
        string elevText  = result.IsElevated ? "Elevated (Admin)" : "Standard User";
 
        sb.Append("<!DOCTYPE html>\n");
        sb.Append("<html lang=\"en\">\n<head>\n");
        sb.Append("  <meta charset=\"UTF-8\">\n");
        sb.Append("  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n");
        sb.AppendFormat("  <title>WinSecAudit Report - {0} - {1:yyyy-MM-dd}</title>\n", result.HostName, result.Timestamp);
        sb.Append("  <style>\n");
        sb.Append("    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');\n");
        sb.Append("    :root {\n");
        sb.Append("      --bg:#0a0a0f;--bg-card:#0f0f1a;--bg-row:#12121f;--border:#1e1e35;--border-glow:#2a2a50;\n");
        sb.Append("      --text:#c8c8e0;--text-muted:#5a5a7a;--text-dim:#3a3a5a;--accent:#4c9fff;\n");
        sb.Append("      --pass:#30d158;--info:#64d2ff;--low:#a8c7fa;--medium:#ffd60a;--high:#ff6b35;--critical:#ff2d55;\n");
        sb.Append("      --mono:'IBM Plex Mono',monospace;--sans:'IBM Plex Sans',sans-serif;\n");
        sb.Append("    }\n");
        sb.Append("    *{margin:0;padding:0;box-sizing:border-box}\n");
        sb.Append("    body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.6;min-height:100vh}\n");
        sb.Append("    body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);pointer-events:none;z-index:999}\n");
        sb.Append("    .container{max-width:1100px;margin:0 auto;padding:40px 24px 80px}\n");
        sb.Append("    .header{border-bottom:1px solid var(--border);padding-bottom:32px;margin-bottom:40px}\n");
        sb.Append("    .header-top{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;margin-bottom:20px}\n");
        sb.Append("    .tool-name{font-family:var(--mono);font-size:11px;font-weight:500;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;margin-bottom:8px}\n");
        sb.Append("    .report-title{font-family:var(--mono);font-size:28px;font-weight:600;color:#e8e8ff;letter-spacing:-.02em}\n");
        sb.AppendFormat("    .risk-badge{{font-family:var(--mono);font-size:13px;font-weight:600;letter-spacing:.1em;color:{0};border:1px solid {0};padding:8px 20px;flex-shrink:0;position:relative}}\n", riskColor);
        sb.Append("    .risk-badge::before{content:'RISK TIER';display:block;font-size:9px;letter-spacing:.2em;color:var(--text-muted);margin-bottom:2px}\n");
        sb.Append("    .meta-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1px;background:var(--border);border:1px solid var(--border)}\n");
        sb.Append("    .meta-item{background:var(--bg-card);padding:12px 16px}\n");
        sb.Append("    .meta-label{font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.15em;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px}\n");
        sb.Append("    .meta-value{font-family:var(--mono);font-size:13px;color:var(--text)}\n");
        sb.Append("    .score-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:40px}\n");
        sb.Append("    .score-cell{background:var(--bg-card);padding:20px 16px;text-align:center}\n");
        sb.Append("    .score-num{font-family:var(--mono);font-size:32px;font-weight:600;line-height:1;margin-bottom:6px}\n");
        sb.Append("    .score-label{font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted)}\n");
        sb.Append("    .c-critical{color:var(--critical)}.c-high{color:var(--high)}.c-medium{color:var(--medium)}.c-low{color:var(--low)}.c-pass{color:var(--pass)}\n");
        sb.Append("    .elevation-warning{border:1px solid var(--high);background:rgba(255,107,53,.05);padding:14px 18px;margin-bottom:32px;font-family:var(--mono);font-size:12px;color:var(--high)}\n");
        sb.Append("    .category{margin-bottom:36px}\n");
        sb.Append("    .category-header{display:flex;align-items:center;gap:12px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border)}\n");
        sb.Append("    .category-name{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:#9090c0}\n");
        sb.Append("    .category-count{font-family:var(--mono);font-size:10px;color:var(--text-dim)}\n");
        sb.Append("    .finding{border:1px solid var(--border);margin-bottom:4px;transition:border-color .15s}\n");
        sb.Append("    .finding:hover{border-color:var(--border-glow)}\n");
        sb.Append("    .finding-header{display:grid;grid-template-columns:90px 1fr auto;align-items:center;gap:16px;padding:12px 16px;cursor:pointer;background:var(--bg-card)}\n");
        sb.Append("    .finding-header:hover{background:var(--bg-row)}\n");
        sb.Append("    .sev-tag{font-family:var(--mono);font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:3px 8px;text-align:center;border:1px solid currentColor}\n");
        sb.Append("    .sev-CRITICAL{color:var(--critical);border-color:var(--critical);background:rgba(255,45,85,.08)}\n");
        sb.Append("    .sev-HIGH{color:var(--high);border-color:var(--high);background:rgba(255,107,53,.08)}\n");
        sb.Append("    .sev-MEDIUM{color:var(--medium);border-color:var(--medium);background:rgba(255,214,10,.06)}\n");
        sb.Append("    .sev-LOW{color:var(--low);border-color:var(--low);background:rgba(168,199,250,.06)}\n");
        sb.Append("    .sev-PASS{color:var(--pass);border-color:var(--pass);background:rgba(48,209,88,.06)}\n");
        sb.Append("    .sev-INFO{color:var(--info);border-color:var(--info);background:rgba(100,210,255,.06)}\n");
        sb.Append("    .finding-title{font-size:13px;color:var(--text)}\n");
        sb.Append("    .finding-control{font-family:var(--mono);font-size:10px;color:var(--text-muted);margin-top:2px}\n");
        sb.Append("    .expand-icon{font-family:var(--mono);font-size:12px;color:var(--text-dim);transition:transform .2s;user-select:none}\n");
        sb.Append("    .finding-body{display:none;padding:16px;border-top:1px solid var(--border);background:var(--bg)}\n");
        sb.Append("    .finding-body.open{display:block}\n");
        sb.Append("    .expand-icon.open{transform:rotate(90deg)}\n");
        sb.Append("    .detail-section{margin-bottom:14px}\n");
        sb.Append("    .detail-label{font-family:var(--mono);font-size:9px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);margin-bottom:4px}\n");
        sb.Append("    .detail-value{font-family:var(--mono);font-size:12px;color:var(--text);white-space:pre-wrap;word-break:break-word}\n");
        sb.Append("    .remediation-box{border-left:2px solid var(--accent);padding:12px 14px;background:rgba(76,159,255,.04)}\n");
        sb.Append("    .remediation-box .detail-label{color:var(--accent)}\n");
        sb.Append("    .remediation-box .detail-value{color:#a0c0ff;font-size:12px}\n");
        sb.Append("    .footer{margin-top:60px;padding-top:20px;border-top:1px solid var(--border);font-family:var(--mono);font-size:10px;color:var(--text-dim);display:flex;justify-content:space-between}\n");
        sb.Append("    @media print{.finding-body{display:block!important}body::before{display:none}}\n");
        sb.Append("  </style>\n</head>\n<body>\n<div class=\"container\">\n\n");
 
        // Header
        sb.Append("  <div class=\"header\">\n    <div class=\"header-top\">\n      <div>\n");
        sb.Append("        <div class=\"tool-name\">WinSecAudit v1.0 // Security Posture Assessment</div>\n");
        sb.AppendFormat("        <div class=\"report-title\">{0}</div>\n", result.HostName);
        sb.Append("      </div>\n");
        sb.AppendFormat("      <div class=\"risk-badge\">{0}</div>\n", result.RiskTier);
        sb.Append("    </div>\n    <div class=\"meta-grid\">\n");
        sb.AppendFormat("      <div class=\"meta-item\"><div class=\"meta-label\">Generated</div><div class=\"meta-value\">{0:yyyy-MM-dd HH:mm} UTC</div></div>\n", result.Timestamp);
        sb.AppendFormat("      <div class=\"meta-item\"><div class=\"meta-label\">Host</div><div class=\"meta-value\">{0}</div></div>\n", result.HostName);
        sb.AppendFormat("      <div class=\"meta-item\"><div class=\"meta-label\">OS</div><div class=\"meta-value\">{0}</div></div>\n", result.OSVersion);
        sb.AppendFormat("      <div class=\"meta-item\"><div class=\"meta-label\">Run As</div><div class=\"meta-value\">{0}</div></div>\n", result.CurrentUser);
        sb.AppendFormat("      <div class=\"meta-item\"><div class=\"meta-label\">Elevation</div><div class=\"meta-value\" style=\"color:{0}\">{1}</div></div>\n", elevColor, elevText);
        sb.Append("    </div>\n  </div>\n\n");
 
        if (!result.IsElevated)
        {
            sb.Append("  <div class=\"elevation-warning\"><strong>NOT ELEVATED:</strong> Re-run as Administrator for complete results.</div>\n\n");
        }
 
        // Score grid
        sb.Append("  <div class=\"score-grid\">\n");
        sb.AppendFormat("    <div class=\"score-cell\"><div class=\"score-num c-critical\">{0}</div><div class=\"score-label\">Critical</div></div>\n", result.CriticalCount);
        sb.AppendFormat("    <div class=\"score-cell\"><div class=\"score-num c-high\">{0}</div><div class=\"score-label\">High</div></div>\n", result.HighCount);
        sb.AppendFormat("    <div class=\"score-cell\"><div class=\"score-num c-medium\">{0}</div><div class=\"score-label\">Medium</div></div>\n", result.MediumCount);
        sb.AppendFormat("    <div class=\"score-cell\"><div class=\"score-num c-low\">{0}</div><div class=\"score-label\">Low</div></div>\n", result.LowCount);
        sb.AppendFormat("    <div class=\"score-cell\"><div class=\"score-num c-pass\">{0}</div><div class=\"score-label\">Pass</div></div>\n", result.PassCount);
        sb.Append("  </div>\n\n");
 
        // Findings
        foreach (var group in categories)
        {
            var orderedFindings = group
                .OrderBy(f => f.Severity == Severity.Pass ? 99 : (int)f.Severity * -1)
                .ToList();
 
            sb.Append("  <div class=\"category\">\n    <div class=\"category-header\">\n");
            sb.AppendFormat("      <span class=\"category-name\">{0}</span>\n", group.Key);
            sb.AppendFormat("      <span class=\"category-count\">({0} finding{1})</span>\n", group.Count(), group.Count() == 1 ? "" : "s");
            sb.Append("    </div>\n");
 
            foreach (var finding in orderedFindings)
            {
                string sevClass  = finding.Severity.ToString().ToUpper();
                string fid       = "f" + Guid.NewGuid().ToString("N").Substring(0, 8);
                string det       = HtmlEncode(finding.Detail);
                string desc      = HtmlEncode(finding.Description);
                string rem       = HtmlEncode(finding.Remediation);
                string ctrl      = HtmlEncode(finding.Control);
 
                sb.AppendFormat("    <div class=\"finding\">\n      <div class=\"finding-header\" onclick=\"toggle('{0}')\">\n", fid);
                sb.AppendFormat("        <span class=\"sev-tag sev-{0}\">{1}</span>\n", sevClass, finding.Severity);
                sb.AppendFormat("        <div><div class=\"finding-title\">{0}</div><div class=\"finding-control\">{1}</div></div>\n", desc, ctrl);
                sb.AppendFormat("        <span class=\"expand-icon\" id=\"icon-{0}\">&#9658;</span>\n", fid);
                sb.Append("      </div>\n");
                sb.AppendFormat("      <div class=\"finding-body\" id=\"body-{0}\">\n", fid);
                sb.AppendFormat("        <div class=\"detail-section\"><div class=\"detail-label\">Technical Detail</div><div class=\"detail-value\">{0}</div></div>\n", det);
                sb.AppendFormat("        <div class=\"remediation-box\"><div class=\"detail-label\">Remediation</div><div class=\"detail-value\">{0}</div></div>\n", rem);
                sb.Append("      </div>\n    </div>\n");
            }
 
            sb.Append("  </div>\n\n");
        }
 
        // Footer + script
        sb.Append("  <div class=\"footer\">\n");
        sb.Append("    <span>WinSecAudit v1.0 - github.com/YOUR_USERNAME/win-sec-audit</span>\n");
        sb.AppendFormat("    <span>Report generated {0:yyyy-MM-dd HH:mm:ss} UTC</span>\n", result.Timestamp);
        sb.Append("  </div>\n\n</div>\n");
        sb.Append("<script>\nfunction toggle(id){\n  var b=document.getElementById('body-'+id);\n  var i=document.getElementById('icon-'+id);\n  b.classList.toggle('open');i.classList.toggle('open');\n}\n</script>\n</body>\n</html>\n");
 
        return sb.ToString();
    }
 
    private static string HtmlEncode(string text) =>
        System.Net.WebUtility.HtmlEncode(text)
            .Replace("\n", "<br>")
            .Replace("  ", "&nbsp;&nbsp;");
}
